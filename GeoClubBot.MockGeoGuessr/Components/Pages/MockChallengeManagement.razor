@page "/mock/challenges"
@rendermode InteractiveServer

<h3>Challenges</h3>
<p class="text-muted">Manage challenges and their highscores.</p>

<!-- Create Challenge -->
<div class="card mb-4">
    <div class="card-header">Create New Challenge</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Map</label>
                <input class="form-control" @bind="_newMap" placeholder="world" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Time Limit (sec)</label>
                <input class="form-control" type="number" @bind="_newTimeLimit" />
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="_newForbidMoving" id="noMove" />
                    <label class="form-check-label" for="noMove">No Move</label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="_newForbidRotating" id="noRotate" />
                    <label class="form-check-label" for="noRotate">No Rotate</label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="_newForbidZooming" id="noZoom" />
                    <label class="form-check-label" for="noZoom">No Zoom</label>
                </div>
            </div>
            <div class="col-md-1">
                <button class="btn btn-success" @onclick="CreateChallenge">Create</button>
            </div>
        </div>
    </div>
</div>

<!-- Challenges List -->
@foreach (var (token, request) in DataStore.Challenges)
{
    var highscores = DataStore.ChallengeHighscores.TryGetValue(token, out var hs) ? hs.ToList() : [];
    var isExpanded = _expandedChallenge == token;

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center"
             @onclick="() => ToggleExpand(token)" style="cursor: pointer;">
            <span>
                <strong>@token</strong>
                <span class="text-muted ms-2">Map: @request.Map | Time: @request.TimeLimit s | Scores: @highscores.Count</span>
            </span>
            <span>@(isExpanded ? "▲" : "▼")</span>
        </div>

        @if (isExpanded)
        {
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-2"><strong>Map:</strong> @request.Map</div>
                    <div class="col-md-2"><strong>Time:</strong> @request.TimeLimit s</div>
                    <div class="col-md-2"><strong>No Move:</strong> @request.ForbidMoving</div>
                    <div class="col-md-2"><strong>No Rotate:</strong> @request.ForbidRotating</div>
                    <div class="col-md-2"><strong>No Zoom:</strong> @request.ForbidZooming</div>
                </div>

                <!-- Add Score -->
                <h6>Add Score</h6>
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-3">
                        <label class="form-label">User</label>
                        <select class="form-select form-select-sm" @bind="_addScoreUserId">
                            <option value="">-- Select user --</option>
                            @foreach (var user in DataStore.Users.Values.OrderBy(u => u.Nick))
                            {
                                <option value="@user.Id">@user.Nick</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Total Score</label>
                        <input class="form-control form-control-sm" type="number" @bind="_addScoreAmount" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Distance (m)</label>
                        <input class="form-control form-control-sm" type="number" @bind="_addScoreDistance" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-sm btn-success" @onclick="() => AddScore(token)"
                                disabled="@(string.IsNullOrEmpty(_addScoreUserId))">Add Score</button>
                    </div>
                </div>

                <!-- Highscores Table -->
                @if (highscores.Count > 0)
                {
                    <h6>Highscores</h6>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Player</th>
                                <th>Score</th>
                                <th>Distance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var item in highscores.OrderByDescending(h =>
                                int.TryParse(h.Game.Player.TotalScore.Amount, out var s) ? s : 0))
                            {
                                <tr>
                                    <td>@rank</td>
                                    <td>@item.Game.Player.Nick</td>
                                    <td>@item.Game.Player.TotalScore.Amount @item.Game.Player.TotalScore.Unit</td>
                                    <td>@item.Game.Player.TotalDistance.Meters.Amount @item.Game.Player.TotalDistance.Meters.Unit</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No scores recorded yet.</p>
                }
            </div>
        }
    </div>
}

@if (DataStore.Challenges.IsEmpty)
{
    <div class="alert alert-info">No challenges created yet.</div>
}

@code {
    [Inject] private MockGeoGuessrDataStore DataStore { get; set; } = default!;

    // Create challenge form
    private string _newMap = "world";
    private int _newTimeLimit = 60;
    private bool _newForbidMoving;
    private bool _newForbidRotating;
    private bool _newForbidZooming;

    // Add score form
    private string _addScoreUserId = "";
    private int _addScoreAmount = 25000;
    private int _addScoreDistance = 100;

    private string? _expandedChallenge;

    private void ToggleExpand(string token)
    {
        _expandedChallenge = _expandedChallenge == token ? null : token;
    }

    private void CreateChallenge()
    {
        var token = DataStore.GenerateChallengeToken();
        DataStore.Challenges[token] = new PostChallengeRequestDto
        {
            AccessLevel = 0,
            ChallengeType = 0,
            ForbidMoving = _newForbidMoving,
            ForbidRotating = _newForbidRotating,
            ForbidZooming = _newForbidZooming,
            Map = _newMap,
            TimeLimit = _newTimeLimit
        };
        DataStore.ChallengeHighscores[token] = [];
        DataStore.NotifyDataChanged();
    }

    private void AddScore(string challengeId)
    {
        if (string.IsNullOrEmpty(_addScoreUserId)) return;
        if (!DataStore.Users.TryGetValue(_addScoreUserId, out var user)) return;

        var scores = DataStore.ChallengeHighscores.GetOrAdd(challengeId, _ => []);
        scores.Add(new ChallengeResultItemDto
        {
            Game = new ChallengeResultGameDto
            {
                Player = new ChallengeResultPlayerDto
                {
                    Id = user.Id,
                    Nick = user.Nick,
                    TotalScore = new ChallengeResultPlayerScoreDto
                    {
                        Amount = _addScoreAmount.ToString(),
                        Unit = "points"
                    },
                    TotalDistance = new ChallengeResultPlayerDistanceDto
                    {
                        Meters = new ChallengeResultPlayerDistanceMetersDto
                        {
                            Amount = _addScoreDistance.ToString(),
                            Unit = "m"
                        }
                    }
                }
            }
        });

        _addScoreUserId = "";
        _addScoreAmount = 25000;
        _addScoreDistance = 100;
        DataStore.NotifyDataChanged();
    }
}
